NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Required for encrypted Gmail token storage
MISSION_CONTROL_SECRET=replace-with-a-long-random-secret

# Used by the application package generation flow
OPENAI_API_KEY=

# Optional providers and integrations
OPENROUTER_API_KEY=
GEMINI_API_KEY=
VOYAGE_API_KEY=
BRAVE_API_KEY=
BRAVE_SEARCH_API_KEY=
X_BEARER_TOKEN=

# Gmail feedback loop
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram agent inbox
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional rendering and overlay settings
LINKEDIN_TEMPLATE_PATH=public/templates/linkedin_base.png
IVE_ALLOW_GENERATIVE_FALLBACK=false

# Optional scheduler override
DAILY_SUMMARY_CRONS=0 15 * * *,0 21 * * *
DAILY_SUMMARY_TIMEZONE=Europe/Amsterdam
