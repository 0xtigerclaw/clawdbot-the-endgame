{
  "manifest_version": 3,
  "name": "Clawdbot the Endgame Form Filler",
  "version": "0.1.0",
  "description": "Scan form fields on the active tab, generate contextual answers via Clawdbot the Endgame, and auto-fill live.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "tabGroups", "webNavigation"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Clawdbot the Endgame Form Filler"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
